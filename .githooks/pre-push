#!/usr/bin/env bash
# pre-push hook — DesignReviewer (Software Limpio)
#
# Corre DesignReviewer antes de hacer push a 'develop'.
# Bloquea el push si hay violaciones CRITICAL.
# Solo se activa al pushear a develop (no en feature branches).

BRANCH=$(git rev-parse --abbrev-ref HEAD)
TARGET_BRANCH=""

# Leer la rama destino del push
while read local_ref local_sha remote_ref remote_sha; do
  TARGET_BRANCH=$(echo "$remote_ref" | sed 's|refs/heads/||')
done

if [[ "$TARGET_BRANCH" != "develop" ]]; then
  exit 0
fi

echo "🔍 DesignReviewer — analizando src/ antes del merge a develop..."
echo ""

designreviewer src/
EXIT_CODE=$?

if [[ $EXIT_CODE -ne 0 ]]; then
  echo ""
  echo "❌ DesignReviewer encontró violaciones CRITICAL."
  echo "   Corregir antes de mergear a develop."
  echo "   Ver docs/plans/WORKFLOW-DESARROLLO.md → Ciclo por Incremento"
  exit 1
fi

echo ""
echo "✅ DesignReviewer: sin violaciones CRITICAL — push permitido."
exit 0
